{
    "name": "f-okazaki/phalcon-sqlsrv",
    "description": "Phalcon - MS SQL Server (PDO) Adapter (Phalcon 4 compatible fork)",
    "keywords": ["framework", "phalcon", "sqlsrv"],
    "authors": [{
        "name": "ToNict",
        "email": "shinobi.wk@hotmail.com"
    },{
        "name": "Baka",
        "email": "info@mctekk.com"
    },{
        "name": "Sage IT Solutions",
        "email": "daniel.davis@sageitsolutions.net"
    },{
        "name": "Futoshi Okazaki",
        "email": "fut.oka@gmail.com"
    }],
    "support": {
        "issues": "https://github.com/ai-zamurai/phalcon-sqlsrv/issues",
        "source": "https://github.com/ai-zamurai/phalcon-sqlsrv"
    },
    "require": {
        "php": ">=7.4",
        "ext-pdo": "*",
        "ext-phalcon": ">= 4.0"
    },
    "require-dev": {
        "codeception/verify": "*"
    },
    "autoload": {
        "psr-4": {
            "Phalcon\\Db\\": "Phalcon/Db/",
            "Phalcon\\Logger\\": "Phalcon/Logger/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalcon\\Db\\": "Phalcon/Db/",
            "Phalcon\\Logger\\": "Phalcon/Logger/"
        }
    }
}
